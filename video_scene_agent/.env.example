# Environment variables for Video Scene Agent

# OpenRouter API Key (required)
OPENROUTER_API_KEY=sk-or-...

# Kling API keys for direct Kling 3.0 Standard video generation/repair
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key

# Kling 3.0 Standard settings (optional, defaults shown)
# KLING_API_BASE=https://api-singapore.klingai.com
# KLING_VIDEO_MODEL=kling-v3-omni
# KLING_MODE=std
# KLING_SOUND=off
# KLING_POLL_TIMEOUT_SEC=900
# KLING_POLL_REQUEST_TIMEOUT_SEC=30
# KLING_POLL_INTERVAL_SEC=2.0
# Hard per-run Kling resource-unit budget. When exhausted, runtime stops paid
# Kling calls, keeps existing edited segments, and fills missing generated
# segments with local FFmpeg still clips so the final video can still stitch.
# KLING_RUN_TOKEN_LIMIT=60
# KLING_GENERATION_TOKENS_PER_SECOND=0.6
# KLING_EDIT_TOKENS_PER_SECOND=0.9
# Kling input media bridge. Enabled by default so local keyframes/segments can
# be sent to Kling as public HTTPS tmpfiles URLs without configuring a CDN.
# KLING_USE_TMPFILES=1
# KLING_TMPFILES_UPLOAD_URL=https://tmpfiles.org/api/v1/upload
# KLING_TMPFILES_TTL_SEC=172800
# KLING_TMPFILES_MAX_BYTES=100000000
# KLING_TMPFILES_TIMEOUT_SEC=120

# Artifact root for generated runs (default: ./artifacts)
STORAGE_PATH=./artifacts
# Optional alias for STORAGE_PATH:
# SCENE_AGENT_ARTIFACTS_ROOT=./artifacts

# Optional public URL base for the artifact root. Runtime appends /runs/<run_id>/...
# Kling inputs use tmpfiles by default; this is mainly for Prefect/public artifact links.
# STORAGE_PUBLIC_URL_BASE=https://example.com/artifacts
# Optional separate public HTTPS base for media URLs sent to Kling when
# KLING_USE_TMPFILES=0 and you provide your own public/signed media hosting.
# Runtime also appends /runs/<run_id>/...
# KLING_MEDIA_PUBLIC_URL_BASE=https://media.example.com/artifacts

# Prefect runtime/deployment settings (optional for local direct run)
# PREFECT_API_URL=http://127.0.0.1:4200/api
# PREFECT_WORK_POOL=video-scene-agent
# PREFECT_DOCKER_IMAGE=video-scene-agent:latest
# PREFECT_SERVER_API_AUTH_STRING=admin:replace-with-long-random-password
# PREFECT_API_AUTH_STRING=admin:replace-with-long-random-password

# OpenRouter models (optional, defaults shown)
# OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash
# OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
# OPENROUTER_VIDEO_MODEL=google/gemini-2.5-flash

# Default generation parameters (optional)
# DEFAULT_ASPECT_RATIO=16:9
# DEFAULT_FPS=24
# DEFAULT_K_SB=3
# DEFAULT_K_VID=2
# IMAGE_SIZE=1024x1024
# REQUEST_TIMEOUT=120
# MAX_RETRIES=3

# Low-cost live smoke overrides (set intentionally when running paid smoke)
# RUN_LIVE_SMOKE=1
# IMAGE_SIZE=512x512
